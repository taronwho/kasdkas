        const forbiddenCharsPattern = /[\u0400-\u04FF\u0500-\u052F\u0370-\u03FF\u0600-\u06FF\u4E00-\u9FFF\u3040-\u30FFåæøłśżźćąęőűșț]/i;
        const nonEnglishCharsPattern = /[çàèéêëîïôùûüñ¿¡ßäö]/i;

        const cleanString = (str) => {
            if (!str) return "";
            let cleaned = str.split('(')[0].split('[')[0].split(' - ')[0].trim();
            return cleaned.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9]/g, ""); 
        };

        const getLevenshteinDistance = (a, b) => {
            if (a.length === 0) return b.length;
            if (b.length === 0) return a.length;
            const matrix = [];
            for (let i = 0; i <= b.length; i++) { matrix[i] = [i]; }
            for (let j = 0; j <= a.length; j++) { matrix[0][j] = j; }
            for (let i = 1; i <= b.length; i++) {
                for (let j = 1; j <= a.length; j++) {
                if (b.charAt(i - 1) === a.charAt(j - 1)) {
                    matrix[i][j] = matrix[i - 1][j - 1];
                } else {
                    matrix[i][j] = Math.min(matrix[i - 1][j - 1] + 1, Math.min(matrix[i][j - 1] + 1, matrix[i - 1][j] + 1));
                }
                }
            }
            return matrix[b.length][a.length];
        };

        const isMatch = (guess, actual) => {
            if (!guess || !guess.trim()) return false;
            const normGuess = cleanString(guess);
            const normActual = cleanString(actual);
            if (normGuess === normActual) return true;
            if (normActual.includes(normGuess) && normGuess.length > 3) return true;
            const distance = getLevenshteinDistance(normGuess, normActual);
            const maxLength = Math.max(normGuess.length, normActual.length);
            const similarity = (maxLength - distance) / maxLength;
            return similarity >= 0.70; 
        };

        const fetchDeezerHit = (term) => {
            return new Promise((resolve) => {
                const callbackName = 'deezer_' + Math.random().toString(36).substr(2, 9);
