// --- AUTOMATICKÁ EXTRAKCE INTERPRETŮ Z DATABÁZÍ ---
        
        // 1. Vytáhneme jména z žánrů (jsou to čistá pole jmen)
        const artistsFromGenres = Object.values(GENRES_DATA).flat();

        // 2. Vytáhneme jména z dekád (vytáhneme text mezi artist:"...")
        const artistsFromDecades = Object.values(DECADES_DATA).flat().map(entry => {
            const match = entry.match(/artist:"([^"]+)"/);
            return match ? match[1] : null;
        }).filter(Boolean);

        // 3. Spojíme vše dohromady (včetně tvých ručních seznamů) a odstraníme duplicity
        const ALL_ARTISTS = Array.from(new Set([
            ...PRIORITY_ARTISTS, 
