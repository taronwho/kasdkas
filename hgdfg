                const timeout = setTimeout(() => { cleanup(); resolve({ data: [] }); }, 4000);
                const cleanup = () => {
                    clearTimeout(timeout);
                    if(document.body.contains(script)) document.body.removeChild(script);
                    delete window[callbackName];
                };
                window[callbackName] = (response) => { cleanup(); resolve(response); };
                script.onerror = () => { cleanup(); resolve({ data: [] }); };
                script.src = `https://api.deezer.com/search?q=${encodeURIComponent(term)}&limit=100&output=jsonp&callback=${callbackName}`;
