                            if (artistName.includes('karaoke') || artistName.includes('tribute') || titleName.includes('karaoke') || artistName.includes('cover') || artistName.includes('deezer') || artistName.includes('sound') || titleName.includes('sleep') || titleName.includes('rain') || titleName.includes('noise')) return false;
                            
