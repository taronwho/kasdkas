                const q = encodeURIComponent(songObj.artistName + ' ' + songObj.trackName);
                const cbName = 'dzfix_mp_' + Math.random().toString(36).substr(2, 9);
                const script = document.createElement('script');
                window[cbName] = (res) => {
                    if (res?.data?.[0]?.preview && audioRef.current) {
                        audioRef.current.src = res.data[0].preview.replace(/^http:\/\//i, 'https://');
                        audioRef.current.play().then(() => setIsPlaying(true)).catch(() => setIsPlaying(false));
                    }
                    if (audioRef.current) audioRef.current.dataset.fixing = "false";
