                                                                title={choice}
                                                            >
                                                                <span className="opacity-50 mr-2">{["A", "B", "C", "D"][i]}</span> {choice}
                                                            </button>
                                                        );
                                                    })}
                                                </div>
                                            ) : (
                                                <>
                                                    {currentGame.gameMode !== 'artist' && (
                                                        <div className="relative w-full">
                                                            <input type="text" placeholder={t.guessArtistPH} value={artistGuess} onChange={(e) => setArtistGuess(e.target.value)} className="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-pink-500 text-center" autoComplete="off"/>
                                                        </div>
                                                    )}
                                                    <input type="text" placeholder={t.guessTrackPH} value={songGuess} onChange={(e) => setSongGuess(e.target.value)} className="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-center" />
                                                </>
                                            )}
                                        </div>
                                        ) : (
                                        <div className="space-y-4 animate-in slide-in-from-bottom-4 fade-in w-full">
                                            <div className="flex justify-center mb-2"><span className={`px-4 py-1.5 rounded-full text-sm font-bold shadow-lg ${guessResult.earned >= 0.5 ? 'bg-green-500' : 'bg-red-500'} text-white whitespace-nowrap`}>{guessResult.earned > 0 ? t.earnedPts(guessResult.earned) : t.wrong}</span></div>
                                            <div>
                                                <h2 className="text-2xl font-bold text-white mb-1 flex items-center justify-center gap-2">{currentSongObj.trackName}{guessResult.song !== null && (guessResult.song ? <CheckCircle className="w-6 h-6 text-green-400 shrink-0" /> : <XCircle className="w-6 h-6 text-red-400 shrink-0" />)}</h2>
                                                {currentGame.gameMode !== 'artist' && (
                                                    <p className="text-lg text-pink-300 font-medium flex items-center justify-center gap-2"><User className="w-4 h-4" />{currentSongObj.artistName}{guessResult.artist !== null && (guessResult.artist ? <CheckCircle className="w-5 h-5 text-green-400 shrink-0" /> : <XCircle className="w-5 h-5 text-red-400 shrink-0" />)}</p>
                                                )}
                                            </div>
                                            <div className="flex flex-col gap-2 text-sm text-slate-300 bg-white/5 p-4 rounded-xl">
                                                <div className="flex items-center gap-2 justify-center">
                                                    <Disc className="w-4 h-4 text-indigo-300" />
                                                    <span className="truncate">{currentSongObj.albumName}</span>
                                                </div>
                                                <div className="flex items-center gap-2 justify-center">
                                                    <TrendingUp className="w-4 h-4 text-indigo-300" />
                                                    <span>{t.scorePop} <strong className="text-white">{currentSongObj.rank.toLocaleString('cs-CZ')}</strong></span>
                                                </div>
                                                <a href={`https://music.youtube.com/search?q=${encodeURIComponent(currentSongObj.artistName + ' ' + currentSongObj.trackName)}`} target="_blank" rel="noopener noreferrer" className="flex items-center gap-2 justify-center mt-3 pt-3 border-t border-white/10 text-pink-400 hover:text-pink-300 font-medium">
                                                    <ExternalLink className="w-4 h-4" /> {t.listenFull}
                                                </a>
                                            </div>
                                        </div>
                                        )}
                                    </div>
                                    <div className="flex flex-col w-full gap-3 mt-4">
                                        {!isRevealed && <button onClick={togglePlay} className={`w-full py-4 rounded-2xl flex items-center justify-center gap-3 font-bold text-lg transition-all ${isPlaying ? 'bg-white/10 text-white' : 'bg-indigo-600 text-white hover:-translate-y-1'}`}>{isPlaying ? <><Pause className="fill-current w-6 h-6" /> {t.pause}</> : <><Play className="fill-current w-6 h-6" /> {t.playPreview}</>}</button>}
                                        {!isRevealed ? ( <button onClick={handleReveal} disabled={currentGame.answerMode === 'choices' && !selectedChoice} className={`w-full py-4 rounded-2xl flex items-center justify-center gap-2 font-medium transition-all ${currentGame.answerMode === 'choices' && !selectedChoice ? 'bg-white/5 text-slate-500 cursor-not-allowed' : 'bg-white/10 hover:bg-white/20 text-white'}`}><Eye className="w-5 h-5" /> {t.reveal}</button>) : (
                                            <button onClick={handleNextRound} className="w-full py-4 rounded-2xl bg-gradient-to-r from-pink-500 to-indigo-500 hover:from-pink-400 hover:to-indigo-400 text-white flex items-center justify-center gap-2 font-bold shadow-lg hover:-translate-y-1">
                                                {currentRound < currentGame.songs.length - 1 ? <><SkipForward className="w-5 h-5 fill-current" /> {t.nextSong}</> : t.finishBtn}
                                            </button>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                );
            }
            return null;
        }

// --- HLAVNÍ OBALOVACÍ KOMPONENTA (Menu nahoře) ---
        function App() {
            const [mode, setMode] = useState(() => localStorage.getItem('musicQuiz_app_mode') || 'singleplayer');
            const [appLang, setAppLang] = useState(() => {
                const saved = localStorage.getItem('musicQuiz_app_lang');
                return LANG_CONFIG[saved] ? saved : 'cs';
            });
            const [isLangMenuOpen, setIsLangMenuOpen] = useState(false);

            useEffect(() => { localStorage.setItem('musicQuiz_app_mode', mode); }, [mode]);
            useEffect(() => { localStorage.setItem('musicQuiz_app_lang', appLang); }, [appLang]);

            const t = DICT[appLang] || DICT['en'];

            return (
                <div className="flex flex-col min-h-screen">
                   {/* HORNÍ LIŠTA - Profesionální responzivní design */}
                    <div className="w-full bg-black/40 backdrop-blur-md border-b border-white/10 p-2 sm:p-3 flex items-center justify-center fixed top-0 z-50 min-h-[4rem]">
                        
                        {/* LEVÁ ČÁST: Logo (Viditelné jen na PC, ukotvené absolutně vlevo) */}
                        <div className="hidden sm:flex absolute left-4 items-center gap-2">
                            <img src="/icon-192.png" alt="Ikona" className="w-7 h-7 rounded-md drop-shadow-md" />
                            <span className="font-black text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-indigo-400 tracking-widest text-lg whitespace-nowrap">
                                {t.appTitle}
                            </span>
                        </div>
                        
                        {/* STŘEDNÍ ČÁST: Tlačítka (Maximum prostoru na mobilu, ikonka nad textem) */}
                        <div className="flex justify-center gap-2 sm:gap-4 w-full pl-2 pr-14 sm:px-0 max-w-sm sm:max-w-lg">
                            <button 
                                onClick={() => setMode('singleplayer')}
                                className={`flex-1 px-1 py-1.5 sm:px-6 sm:py-2 rounded-xl sm:rounded-full font-bold transition-all flex flex-col sm:flex-row items-center justify-center gap-1 sm:gap-2 text-[10px] sm:text-lg leading-tight shadow-lg ${mode === 'singleplayer' ? 'bg-pink-500 text-white' : 'bg-white/10 text-slate-300 hover:bg-white/20'}`}
                            >
                                <Music className="w-4 h-4 sm:w-5 sm:h-5 shrink-0" /> 
                                <span className="whitespace-normal text-center break-words">{t.training}</span>
                            </button>
                            <button 
                                onClick={() => {
                                    if (mode === 'multiplayer') window.dispatchEvent(new Event('return-to-mp-dashboard'));
                                    setMode('multiplayer');
                                }}
                                className={`flex-1 px-1 py-1.5 sm:px-6 sm:py-2 rounded-xl sm:rounded-full font-bold transition-all flex flex-col sm:flex-row items-center justify-center gap-1 sm:gap-2 text-[10px] sm:text-lg leading-tight shadow-lg ${mode === 'multiplayer' ? 'bg-indigo-500 text-white' : 'bg-white/10 text-slate-300 hover:bg-white/20'}`}
                            >
                                <Swords className="w-4 h-4 sm:w-5 sm:h-5 shrink-0" /> 
                                <span className="whitespace-normal text-center break-words">{t.multiplayer}</span>
                            </button>
                        </div>

                        {/* PRAVÁ ČÁST: Jazykové menu (Absolutně napravo pro úsporu místa) */}
                        <div className="absolute right-2 sm:right-4 flex justify-end">
                            <button 
                                onClick={() => setIsLangMenuOpen(!isLangMenuOpen)} 
                                className="flex items-center justify-between gap-1 sm:gap-2 text-white px-2 py-2 sm:px-3 sm:py-2 rounded-xl bg-white/10 hover:bg-white/20 border border-white/20 transition-all font-bold text-xs sm:text-sm"
                            >
                                <div className="flex items-center gap-2">
                                    <img src={`https://flagcdn.com/w20/${LANG_CONFIG[appLang].code}.png`} alt="flag" className="w-4 sm:w-5 rounded-[2px] shadow-sm" />
                                    <span className="hidden sm:inline">{LANG_CONFIG[appLang].name}</span>
                                </div>
                                <span className="text-[10px] opacity-70 ml-1">{isLangMenuOpen ? '▲' : '▼'}</span>
                            </button>

                            {isLangMenuOpen && (
                                <div className="absolute top-full right-0 mt-2 bg-slate-800 border border-white/20 rounded-xl shadow-2xl py-2 w-48 sm:w-56 z-50 origin-top-right max-h-[70vh] overflow-y-auto custom-scrollbar">
                                    {Object.keys(LANG_CONFIG).map((langKey) => (
                                        <button 
                                            key={langKey}
                                            onClick={() => { setAppLang(langKey); setIsLangMenuOpen(false); }}
                                            className={`w-full text-left px-4 py-2.5 flex items-center gap-3 transition-colors ${appLang === langKey ? 'bg-indigo-600 text-white font-bold' : 'text-slate-300 hover:bg-white/10 hover:text-white font-medium'}`}
                                        >
                                            <img src={`https://flagcdn.com/w20/${LANG_CONFIG[langKey].code}.png`} alt="flag" className="w-5 shrink-0 rounded-[2px] shadow-sm drop-shadow-md" />
                                            <span className="leading-tight">{LANG_CONFIG[langKey].name}</span>
                                        </button>
                                    ))}
                                </div>
                            )}
                        </div>
                    </div>

                    {isLangMenuOpen && (
                        <div className="fixed inset-0 z-40" onClick={() => setIsLangMenuOpen(false)}></div>
                    )}

                    <div className="flex-1 pt-16 pb-8">
                        {/* VELKÉ LOGO PRO MOBILY */}
                        <div className="flex sm:hidden flex-col items-center justify-center pt-6 pb-2 animate-in zoom-in-95 duration-500">
                            <img src="/icon-192.png" alt="Ikona hry" className="w-16 h-16 rounded-2xl drop-shadow-2xl shadow-indigo-500/20 mb-2" />
                            <h1 className="font-black text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-indigo-400 tracking-[0.2em] text-2xl whitespace-nowrap drop-shadow-sm">
                                {t.appTitle}
                            </h1>
                        </div>

                        {mode === 'singleplayer' ? <SingleplayerMode appLang={appLang} t={t} /> : <MultiplayerMode appLang={appLang} t={t} />}
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
